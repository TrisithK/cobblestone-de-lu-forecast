# Copy this file to .env and fill in your keys.
# .env is in .gitignore — never commit it.

# ENTSO-E Transparency Platform API key
# Register at: https://transparency.entsoe.eu → My Account → Security token
ENTSOE_API_KEY=your_token_here

# Anthropic API key (only needed to regenerate LLM commentary; cached outputs work without it)
# Get from: https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...
